generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  passwordHash     String
  name             String
  boards           Board[]
  boardMemberships BoardMember[]
  activities       Activity[]
  comments         Comment[]
  assignedTasks    Task[]        @relation("TaskAssignee")
  assignedByTasks  Task[]        @relation("TaskAssigner")
  archivedTasks    Task[]        @relation("TaskArchivedBy")
  createdAt        DateTime      @default(now())
}

model Board {
  id         String        @id @default(cuid())
  title      String
  owner      User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId    String
  columns    Column[]
  members    BoardMember[]
  activities Activity[]
  labels     Label[]
  createdAt  DateTime      @default(now())

  @@index([ownerId])
}

enum BoardRole {
  EDITOR
  VIEWER
}

model BoardMember {
  id        String    @id @default(cuid())
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId   String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      BoardRole @default(EDITOR)
  createdAt DateTime  @default(now())

  @@unique([boardId, userId])
  @@index([userId])
}

model Label {
  id        String   @id @default(cuid())
  title     String
  color     String   @default("#6366f1")
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId   String
  tasks     Task[]
  createdAt DateTime @default(now())

  @@unique([boardId, title])
  @@index([boardId])
}

model Column {
  id           String  @id @default(cuid())
  title        String
  order        Int
  wipLimit     Int?
  isCompletion Boolean @default(false)
  board        Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId      String
  tasks        Task[]

  @@index([boardId, order])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  ACTIVE
  PENDING_REVIEW
  ARCHIVED
}

model Task {
  id             String          @id @default(cuid())
  title          String
  description    String?
  priority       TaskPriority    @default(MEDIUM)
  dueDate        DateTime?
  order          Int
  status         TaskStatus      @default(ACTIVE)
  completedAt    DateTime?
  archivedAt     DateTime?
  column         Column          @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId       String
  assignee       User?           @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId     String?
  assignedBy     User?           @relation("TaskAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedById   String?
  archivedBy     User?           @relation("TaskArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  archivedById   String?
  labels         Label[]
  comments       Comment[]
  checklistItems ChecklistItem[]
  createdAt      DateTime        @default(now())

  @@index([columnId, order])
  @@index([dueDate])
  @@index([assigneeId])
  @@index([status])
  @@index([assignedById])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  content   String
  done      Boolean  @default(false)
  order     Int
  createdAt DateTime @default(now())

  @@index([taskId, order])
}

model Comment {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
}

enum ActivityAction {
  CREATED
  UPDATED
  MOVED
  DELETED
}

// Immutable per-board event log; not FK-linked to Task so entries survive
// task deletion (taskTitle/fromColumn/toColumn are snapshots, not live refs).
model Activity {
  id         String         @id @default(cuid())
  board      Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId    String
  actor      User           @relation(fields: [actorId], references: [id], onDelete: Cascade)
  actorId    String
  action     ActivityAction
  taskTitle  String
  fromColumn String?
  toColumn   String?
  createdAt  DateTime       @default(now())

  @@index([boardId, createdAt])
}
